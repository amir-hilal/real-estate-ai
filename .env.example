# Environment variables for the AI Real Estate Agent
# Copy this file to .env and fill in real values — never commit .env

# ─── Environment ─────────────────────────────────────────
# "development" uses Ollama (local); "production" uses Groq (hosted)
ENVIRONMENT=development

# ─── Ollama (development) ────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=phi4-mini
OLLAMA_TIMEOUT=120

# ─── Groq (production) ───────────────────────────────────
GROQ_API_KEY=gsk_...
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TIMEOUT=120

# ─── Prompt versioning ───────────────────────────────────
EXTRACTION_PROMPT_VERSION=v1
EXPLANATION_PROMPT_VERSION=v1
CHAT_PROMPT_VERSION=v2

# ─── Model artifacts (relative to project root) ──────────
MODEL_PATH=ml/artifacts/model.joblib
TRAINING_STATS_PATH=ml/artifacts/training_stats.json

# ─── Server ──────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ─── CORS (frontend origin allowed to call the API) ──────
CORS_ORIGIN=http://localhost:5173
