# Environment variables for the AI Real Estate Agent
# Copy this file to .env and fill in real values — never commit .env

# LLM
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-4o
EXTRACTION_PROMPT_VERSION=v1
EXPLANATION_PROMPT_VERSION=v1

# Model artifacts (relative to project root)
MODEL_PATH=ml/artifacts/model.joblib
TRAINING_STATS_PATH=ml/artifacts/training_stats.json

# Server
PORT=8000
